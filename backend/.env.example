# ============================================================================
# CampusGuard Backend Environment Variables
# ============================================================================
# This file documents all environment variables required/supported by the
# College Connect (CampusGuard) backend API.
#
# Copy this file to .env and fill in your values for local development.
# For Render deployment, set these via the dashboard or render.yaml envVars.
# For Docker Compose, use docker/.env.example
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port the backend API runs on
# Default: 8080
# Used by: Spring Boot embedded Tomcat
PORT=8080

# ============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# ============================================================================
# 
# DATABASE_URL Format Examples:
#   Local Dev:    postgresql://localhost:5432/college_connect
#   Docker:       postgresql://postgres:5432/college_connect
#   Render:       (auto-injected by Render.com)
#   Remote Host:  postgresql://user:pass@host:port/college_connect
#
# IMPORTANT: Change password and username from defaults in production!

# PostgreSQL connection string (JDBC URL)
# Spring format: jdbc:postgresql://host:port/database
DATABASE_URL=jdbc:postgresql://localhost:5432/college_connect

# Database username
# Default (local dev): college_admin
# Change this in production!
DATABASE_USERNAME=college_admin

# Database password  
# Default (local dev): college_password
# NEVER use this in production! Generate strong password.
DATABASE_PASSWORD=college_password

# Database driver class
# H2 (local dev sandbox): org.h2.Driver
# PostgreSQL (production): org.postgresql.Driver
DATABASE_DRIVER=org.postgresql.Driver

# Hibernate ORM dialect (must match database)
# H2 (local dev): org.hibernate.dialect.H2Dialect
# PostgreSQL (production): org.hibernate.dialect.PostgreSQLDialect
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT token signing secret
# IMPORTANT: Generate a secure random string in production (min 32 bytes)
# Generate with: openssl rand -hex 32
# Default: DO NOT USE IN PRODUCTION
JWT_SECRET=your_super_secure_jwt_secret_key_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxx

# JWT token expiration time in milliseconds
# Default: 86400000 (1 day)
# 7 days: 604800000
# 30 days: 2592000000
JWT_EXPIRATION=86400000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed CORS origins
#
# Local Dev:      http://localhost:5173,http://localhost:3000
# Docker Local:   http://localhost:5173,http://localhost:3000,http://localhost:80
# Production:     https://yourdomain.vercel.app,https://www.yourdomain.vercel.app
# Allow All:      *
#
# SECURITY NOTE: "Allow All Origins (*)" should only be used in development/college projects!
# Restrict to specific domains in production.

ALLOWED_ORIGINS=*

# ============================================================================
# AI INTEGRATION (OPTIONAL)
# ============================================================================

# OpenAI API key for chat integration
# Get from: https://platform.openai.com/api-keys
# Only needed if ChatController uses real OpenAI (currently mocked)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Custom OpenAI base URL (defaults to https://api.openai.com/v1)
# Uncomment to override for custom endpoints
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# LOGGING (OPTIONAL)
# ============================================================================
# Spring Boot logging level
# Valid values: TRACE, DEBUG, INFO, WARN, ERROR, FATAL, OFF
# Default: INFO

# Root logger level (entire application)
# LOGGING_LEVEL_ROOT=INFO

# Application-specific logger (CampusGuard package)
# LOGGING_LEVEL_COM_COLLEGECONNECT=DEBUG

# ============================================================================
# QUICK START GUIDES
# ============================================================================
#
# LOCAL DEVELOPMENT (H2 In-Memory, Fastest)
# ========================================
# DATABASE_URL=jdbc:h2:mem:college_connect;DB_CLOSE_DELAY=-1;MODE=PostgreSQL
# DATABASE_USERNAME=sa
# DATABASE_PASSWORD=
# DATABASE_DRIVER=org.h2.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect
# - No external database needed
# - Fastest startup
# - Data lost on restart
#
# LOCAL DEVELOPMENT (PostgreSQL, Recommended for Production Testing)
# ===================================================================
# DATABASE_URL=jdbc:postgresql://localhost:5432/college_connect
# DATABASE_USERNAME=college_admin
# DATABASE_PASSWORD=college_password
# DATABASE_DRIVER=org.postgresql.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# - Requires: PostgreSQL server running locally
#   Install: https://www.postgresql.org/download/
#   Or use: docker run --name postgres -e POSTGRES_PASSWORD=college_password -p 5432:5432 postgres:16
#
# DOCKER COMPOSE (PostgreSQL + Backend in Containers)
# ===================================================
# See: docker/.env.example
# - Includes PostgreSQL 16 container
# - Auto-creates database and users
# - Use: docker-compose -f docker/docker-compose.yml up
#
# RENDER.COM DEPLOYMENT (Production PostgreSQL)
# ==============================================
# See: backend/RENDER_DEPLOY.md
# - Render auto-creates PostgreSQL database
# - Set these env vars in Render Dashboard:
#   DATABASE_URL, DATABASE_USERNAME, DATABASE_PASSWORD (auto-injected)
#   JWT_SECRET (recommended: auto-generate)
#   ALLOWED_ORIGINS (production domain)
#
# ============================================================================
