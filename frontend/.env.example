# ============================================================================
# CampusGuard Frontend Environment Variables
# ============================================================================
# This file documents environment variables for the frontend React application.
#
# Copy this file to .env.local and fill in your values for local development.
# For Vercel deployment, set these via the Vercel dashboard or vercel.json.
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API base URL
# Local development: Leave empty (Vite proxy handles /api→localhost:8080)
# Production (Vercel): Set to Render backend service URL
# Example: https://college-connect-api-xxxx.onrender.com
# When set, frontend will make HTTPS requests to this URL with Authorization: Bearer token
VITE_API_URL=

# ============================================================================
# VITE BUILD CONFIG (Usually managed by Vercel, not needed to set)
# ============================================================================

# Base path for app routing (if deployed at subdirectory)
# Default: /
# Example: /app if deployed at mydomain.com/app
# BASE_PATH=/

# Dev server port (local development only, not used in Vercel)
# Default: 5173
# PORT=5173

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
#
# 1. LOCAL DEVELOPMENT
#    - Leave VITE_API_URL empty
#    - Vite dev server will proxy /api requests to http://localhost:8080
#    - Run frontend with: pnpm run dev (from frontend/ directory)
#    - Run backend in separate terminal: cd backend && java -jar target/*.jar
#
# 2. LOCAL PRODUCTION BUILD TEST
#    - Set VITE_API_URL=http://localhost:8080 (or actual backend URL)
#    - Build: pnpm run build
#    - Preview: pnpm run serve
#    - This tests the production bundle before deploying to Vercel
#
# 3. VERCEL DEPLOYMENT
#    - Vercel will automatically set VITE_API_URL during build
#    - The backend service (render.yaml) injects it: fromService: college-connect-api
#    - Set in vercel.json or Vercel dashboard
#    - Build command: pnpm install && pnpm run build --filter @workspace/lost-and-found
#    - Output directory: frontend/dist/public
#
# 4. ENVIRONMENT-SPECIFIC BUILD
#    - Create separate .env files: .env.local, .env.production, .env.staging
#    - Vite will load .env.{NODE_ENV} automatically if present
#    - Example: .env.production with VITE_API_URL=https://api.yourdomain.com
#
# ============================================================================
