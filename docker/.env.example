# ============================================================================
# Docker Compose Environment Variables
# ============================================================================
# This file sets environment variables for docker-compose.yml services
# 
# Usage: 
#   1. Copy this file to docker/.env
#   2. Update values as needed
#   3. Run: docker-compose -f docker/docker-compose.yml up
# ============================================================================

# ============================================================================
# POSTGRESQL DATABASE
# ============================================================================

# PostgreSQL database user (for database creation)
POSTGRES_USER=college_admin

# PostgreSQL database password
# IMPORTANT: Change this in production!
POSTGRES_PASSWORD=college_password

# PostgreSQL database name (created automatically on first run)
POSTGRES_DB=college_connect

# ============================================================================
# BACKEND SPRING BOOT SERVICE
# ============================================================================

# Server port (internal to container)
PORT=8080

# JWT Secret for token signing
# Generate: openssl rand -hex 32
# Default (dev only): change in production!
JWT_SECRET=dev_jwt_secret_key_min_32_chars_change_in_production_xxxxxxx

# CORS allowed origins (for backend API)
# Docker local: http://localhost:5173,http://localhost:3000,http://localhost:80
# College project: *
ALLOWED_ORIGINS=*

# ============================================================================
# DATABASE CONNECTION (from Backend to PostgreSQL)
# ============================================================================
# These are automatically generated by docker-compose.yml but shown here for reference
# DATABASE_URL=jdbc:postgresql://postgres:5432/college_connect
# DATABASE_USERNAME=college_admin
# DATABASE_PASSWORD=college_password
# DATABASE_DRIVER=org.postgresql.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ============================================================================
# OPTIONAL: FRONTEND SERVICE
# ============================================================================
# Uncomment frontend service in docker-compose.yml to enable

# Frontend port (internal to container)
# FRONTEND_PORT=3000

# Backend API URL (for frontend to call backend)
# VITE_API_URL=http://localhost:8080

# ============================================================================
# OPTIONAL: AI INTEGRATION
# ============================================================================

# OpenAI API Key (if using real OpenAI integration)
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# QUICK START
# ============================================================================
# 
# 1. Make sure you have Docker and Docker Compose installed
#    https://docs.docker.com/engine/install/
#
# 2. Start services (PostgreSQL + Backend):
#    docker-compose -f docker/docker-compose.yml up -d
#
# 3. Check service status:
#    docker-compose -f docker/docker-compose.yml ps
#
# 4. View logs:
#    docker-compose -f docker/docker-compose.yml logs -f backend
#
# 5. Run backend migrations/init (if needed):
#    docker-compose -f docker/docker-compose.yml exec backend ./init-db.sh
#
# 6. Stop services:
#    docker-compose -f docker/docker-compose.yml down
#
# 7. Stop and remove volumes (reset database):
#    docker-compose -f docker/docker-compose.yml down -v
#
# ============================================================================
